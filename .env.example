PORT=3000

# Database
DB_HOST=your-mysql-host
DB_PORT=your-mysql-port
DB_DATABASE=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your-password

# Aiven TLS (recommended for production)
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
# PEM certificate content encoded in base64
DB_SSL_CA_B64=

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# Local HTTPS only (cloud should keep this false)
USE_HTTPS=false
SSL_KEY_PATH=selfsigned.key
SSL_CERT_PATH=selfsigned.crt
